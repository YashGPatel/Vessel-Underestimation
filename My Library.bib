  pages = {106--122},
  publisher = {OSA},
  doi = {10.1364/BOE.5.000106},
  abstract = {We present a novel polarization sensitive optical coherence tomography (PS-OCT) system with an integrated retinal tracker. The tracking operates at up to 60 Hz, correcting PS-OCT scanning positions during the acquisition to avoid artifacts caused by eye motion. To demonstrate the practical performance of the system, we imaged several healthy volunteers and patients with AMD both with B-scan repetitions for frame averaging and with 3D raster scans. Under large retinal motions with up to 1 mm amplitude at 0.5 \textasciitilde a few Hz frequency range, motion artifact suppression in the PS-OCT images as well as standard deviation noise reduction in the frame averaged retardation images are presented.},
  keywords = {Functional monitoring and imaging,Image quality,Imaging systems,Medical optics and biotechnology,Ophthalmic imaging,Ophthalmology,Optical coherence tomography,Retinal nerve fiber layer,Speckle noise,Speckle reduction,Three dimensional imaging}
