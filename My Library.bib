  journal = {Journal of Biomedical Optics},
  volume = {23},
  number = {8},
  publisher = {SPIE},
  address = {Medical University of Vienna, Center for Medical Physics and Biomedical Engineering, Vienna, Austria},
  issn = {10833668 (ISSN)},
  doi = {10.1117/1.JBO.23.8.086005},
  abstract = {Polarization-sensitive optical coherence tomography (PS-OCT) enables noninvasive, high-resolution imaging of tissue polarization properties. In the anterior segments of human eyes, PS-OCT allows the visualization of birefringent and depolarizing structures. We present the use of PS-OCT for imaging the murine anterior eye. Using a spectral domain PS-OCT setup operating in the 840-nm regime, we performed in vivo volumetric imaging in anesthetized C57BL/6 mice. The polarization properties of murine anterior eye structures largely replicated those known from human PS-OCT imagery, suggesting that the mouse eye may also serve as a model system under polarization contrast. However, dissimilarities were found in the depolarizing structure of the iris which, as we confirmed in postmortem histological sections, were caused by anatomical differences between both species. In addition to the imaging of tissues in the anterior chamber and the iridocorneal angle, we demonstrate longitudinal PS-OCT imaging of the murine anterior segment during mydriasis as well as birefringence imaging of corneal pathology in an aged mouse. \copyright{} The Authors. Published by SPIE under a Creative Commons Attribution 3.0 Unported License. Distribution or reproduction of this work in whole or in part requires full attribution of the original publication, including its DOI.},
  langid = {english},
  keywords = {animal,Animals,Birefringence,birefringence,Birefringence imaging,C57BL mouse,Capillary flow,cataract,Cataract,cornea,Cornea,depolarization,Depolarization,diagnostic imaging,Diagnostic Techniques Ophthalmological,Equipment Design,equipment design,High-resolution imaging,image processing,Image Processing Computer-Assisted,Mammals,Mice,Mice Inbred C57BL,mouse,mydriasis,Mydriasis,Ophthalmology,ophthalmology,optical coherence tomography,Optical tomography,pathology,Polarization,Polarization contrast,Polarization properties,Polarization sensitive optical coherence tomograph,Polarization-sensitive devices,polarization-sensitive devices,procedures,signal processing,Signal Processing Computer-Assisted,Tissue,Tomography Optical Coherence,visual system examination},
