Correspondence Address: Schmetterer, L.; Department of Clinical Pharmacology, Medical University of Vienna, Waehringer Guertel 18-20, Austria}
}

@article{schmidlControlledRandomizedDoubleBlind2017,
  title = {A {{Controlled}}, {{Randomized Double-Blind Study}} to {{Evaluate}} the {{Safety}} and {{Efficacy}} of {{Chitosan-N-Acetylcysteine}} for the {{Treatment}} of {{Dry Eye Syndrome}}},
  author = {Schmidl, D and Werkmeister, R and Kaya, S and Unterhuber, A and Witkowska, K J and Baumgartner, R and H{\"o}ller, S and O'Rourke, M and Peterson, W and Wolter, A and Prinz, M and Schmetterer, L and Garh{\"o}fer, G},
  year = 2017,
  journal = {Journal of Ocular Pharmacology and Therapeutics},
  volume = {33},
  number = {5},
  pages = {375--382},
  publisher = {Mary Ann Liebert Inc.},
  address = {Department of Clinical Pharmacology, Medical University of Vienna, Wahringer Gurtel 18-20, Vienna, 1090, Austria},
  issn = {10807683 (ISSN)},
  doi = {10.1089/jop.2016.0123},
  abstract = {Purpose: This study was designed to evaluate the effect of chitosan-N-acetylcysteine (C-NAC) eye drops on tear film thickness (TFT) in patients with dry eye syndrome (DES). Methods: This was a controlled, randomized, double-blind clinical investigation with patients assigned to 2 cohorts. In Cohort I, 21 patients were randomized to receive 1 instillation of C-NAC eye drops in 1 eye and placebo (normal saline solution) in the contralateral eye. In Cohort II, 17 patients were randomized to receive C-NAC eye drops once (QD) or twice (BID) daily for 5 days. TFT was assessed with a custom-built ultrahigh-resolution optical coherence tomography system. Results: In Cohort I, mean TFT increased from 3.9 \textpm{} 0.5 {$\mu$}m predose to 4.8 \textpm{} 1.1 {$\mu$}m 10 min postdose after treatment with C-NAC. The increase was significantly different from placebo over time (P {$<$} 0.0001) and remained stable until 24 h postdose. In Cohort II, TFT increased with QD and BID instillation, with no significant difference between regimens. In both groups, Ocular Surface Disease Index scores improved, fewer patients presented with corneal damage, and symptoms of ocular discomfort/conjunctival redness were reduced. Conclusions: A single instillation of C-NAC significantly increased mean TFT in patients with DES as early as 10 min after instillation and lasted for 24 h. The magnitude of the increase in TFT following a single instillation was comparable with that after instillation twice daily over 5 days. Corneal damage improved in {$>$}60\% of patients. C-NAC could be a viable treatment option for DES. \copyright{} 2017, Mary Ann Liebert, Inc.},
  langid = {english},
  keywords = {acetylcysteine,Acetylcysteine,Adult,adult,analogs and derivatives,Article,chemistry,chitosan,Chitosan,chitosan-N-acetylcysteine conjugate,clinical assessment,clinical evaluation,cohort analysis,Cohort Studies,controlled study,cornea erosion,cornea injury,double blind procedure,Double-Blind Method,drug efficacy,drug induced headache,drug safety,dry eye,Dry Eye Syndromes,efficacy,eye discomfort,eye drops,eye irritation,eye redness,Female,female,gastroenteritis,human,Humans,intraocular foreign body,intraocular pressure,lacrimal fluid,Male,male,metabolism,ocular pruritus,Ocular Surface Disease Index,optical coherence tomography,placebo,randomized controlled trial,safety,Schirmer test,tear film,Tear film,Tears,Tomography Optical Coherence},
