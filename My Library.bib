@article{garhoferNitricOxideDrug2019,
  title = {Nitric Oxide: A Drug Target for Glaucoma Revisited},
  author = {Garh{\"o}fer, G and Schmetterer, L},
  year = 2019,
  journal = {Drug Discovery Today},
  volume = {24},
  number = {8},
  pages = {1614--1620},
  publisher = {Elsevier Ltd},
  address = {Department of Clinical Pharmacology, Medical University of Vienna, Austria},
  issn = {13596446 (ISSN)},
  doi = {10.1016/j.drudis.2019.05.033},
  abstract = {A reduction in intraocular pressure (IOP) is the only recognized therapy for glaucoma. Hence, drugs exhibiting ocular hypotensive effects are important targets for antiglaucomatous drug development. IOP is determined by the equilibrium of aqueous humor production and outflow through either the trabecular meshwork or the uveoscleral outflow pathway. There is increasing evidence that nitric oxide (NO) has a major role in the regulation of IOP by directly acting on the trabecular meshwork and thereby lowering IOP. Taking advantage of this mechanism, newly designed NO-donating drugs combine the IOP-lowering effect of known substances with the trabecular meshwork outflow-increasing effect of NO. Here, we review the molecular mechanism of this new entity of IOP-lowering drugs. \copyright{} 2019 Elsevier Ltd},
  langid = {english},
  keywords = {animal,Animals,antiglaucoma agent,aqueous humor,Aqueous Humor,drug delivery system,Drug Delivery Systems,drug effect,glaucoma,Glaucoma,human,Humans,intraocular pressure,Intraocular Pressure,metabolism,neuroprotection,neurotransmitter,nitric oxide,Nitric Oxide,nonhuman,procedures,Review,trabecular meshwork},
  note = {Cited By :4

Export Date: 10 June 2020

CODEN: DDTOF

Correspondence Address: Garh\"ofer, G.; Department of Clinical Pharmacology, Medical University of ViennaAustria; email: gerhard.garhoefer@meduniwien.ac.at}
}

