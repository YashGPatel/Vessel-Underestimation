}

@article{schmidlPilotStudyAssess2020,
  title = {A Pilot Study to Assess the Effect of a Three-Month Vitamin Supplementation Containing l-Methylfolate on Systemic Homocysteine Plasma Concentrations and Retinal Blood Flow in Patients with Diabetes},
  author = {Schmidl, Doreen and Howorka, Kinga and Szegedi, Stephan and Stjepanek, Kristina and Puchner, Stefan and Bata, Ahmed and Scheschy, Ulrike and Aschinger, Gerold and Werkmeister, Ren{\'e} M. and Schmetterer, Leopold and Garhofer, Gerhard},
  year = 2020,
  journal = {Molecular Vision},
  volume = {26},
  pages = {326--333},
  publisher = {Molecular Vision},
  address = {Department of Clinical Pharmacology, Medical University of Vienna, Vienna, Austria},
  issn = {10900535},
  abstract = {Purpose: The aim of the present study was to investigate the effect of a three-month dietary supplementation with a methylfolate formulation on homocysteine plasma concentrations and ocular blood flow parameters in patients with diabetes. Methods: Twenty-four patients with diabetes received a dietary supplement (Oculofolin, Aprofol AG, Switzerland) containing 900 {$\mu$}g L-methylfolate (levomefolate calcium or6S]-5-methyltetrahydrofolic acid, calcium salt), methylcobalamin, and other ingredients for three consecutive months. The patients' plasma homocysteine concentration and retinal blood flow were assessed at baseline and after three months of folate intake. Retinal blood flow was measured using a custom-built dual-beam Doppler optical coherence tomography (OCT) system. In addition, flicker-induced retinal vasodilatation was assessed by means of a commercially available dynamic vessel analyzer (IMEDOS, Jena, Germany). Results: Supplementation was well tolerated by all patients. After three months, plasma homocysteine concentration significantly decreased from 14.2 \textpm{} 9.3 to 9.6 \textpm{} 6.6 {$\mu$}mol/L (p {$<$} 0.001). In addition, a tendency toward an increased total retinal blood flow from 36.8 \textpm{} 12.9 to 39.2 \textpm{} 10.8 {$\mu$}l/min was observed, but this effect did not reach the level of significance (p = 0.11). Supplementation had no effect on retinal vessel diameter or flicker-induced vasodilatation. Conclusions: The present data show that a three-month intake of a dietary supplement containing methylfolate can significantly reduce blood homocysteine levels in patients with diabetes. This is of importance because higher homocysteine plasma levels have been found to be associated with an increased risk of vascular associated systemic diseases and eye diseases. Whether systemic methylfolate supplementation affects retinal perfusion must be studied in a larger population.},
  langid = {english},
  note = {Export Date: 10 June 2020

CODEN: MVEPF

Correspondence Address: Garhofer, G.; Department of Clinical Pharmacology, Medical University of Vienna, W\"ahringer G\"urtel 18-20, Austria; email: gerhard.garhoefer@meduniwien.ac.at}
}

@article{schmidlTearFilmThickness2015,
  title = {Tear Film Thickness after Treatment with Artificial Tears in Patients with Moderate Dry Eye Disease},
  author = {Schmidl, D and Schmetterer, L and Witkowska, K J and Unterhuber, A and Dos Santos, V A and Kaya, S and Nepp, J and Baar, C and Rosner, P and Werkmeister, R M and Garhofer, G},
  year = 2015,
  journal = {Cornea},
  volume = {34},
  number = {4},
  pages = {421--426},
  publisher = {{Lippincott Williams and Wilkins}},
  address = {Department of Clinical Pharmacology, Medical University Vienna, Waehringer Guertel 18-20, Vienna, 1090, Austria},
  issn = {02773740 (ISSN)},
  doi = {10.1097/ICO.0000000000000358},
  abstract = {Purpose: This study was designed to investigate the effect of a single-drop instillation of different lacrimal substitutes on tear film thickness (TFT) assessed with optical coherence tomography in patients with mild to moderate dry eye disease. Methods: The study was performed in a randomized, doublemasked, controlled parallel group design. Patients received a single dose of either unpreserved trehalose 30 mg/mL and sodium hyaluronate 1.5 mg/mL (TH-SH, Thealoz Duo), unpreserved sodium hyaluronate, 0.15\% (HA, Hyabak) or sodium chloride, 0.9\% (NaCl, Hydrabak) eye drops. Sixty patients finished the study according to the protocol. TFT was measured with a custom-built ultrahighresolution Fourier domain optical coherence tomography system providing a resolution of 1.2 mm. Results: The mean TFT before treatment was 2.5 6 0.4 mm. Ten minutes after instillation, TFT significantly increased in the THSH group from 2.4 6 0.4 to 3.1 6 0.9 mm (P , 0.01) and in the HA group from 2.4 6 0.3 to 2.9 6 0.5 mm (P , 0.01), whereas no significant change was observed in the NaCl group (from 2.6 6 0.4 to 2.7 6 0.4 mm, P = 0.76). The increase in TFT remained statistically significant up to 240 minutes after administration of THSH. In contrast, the increase in TFT after administration of HA was only statistically significant at 10, 20, and 40 minutes after drop instillation. Conclusions: The findings of this study indicate that single instillation of TH-SH and HA eye drops increases TFT in patients with dry eye disease. The data also indicate longer corneal residence of the TH-containing eye drops. The effect of multiple instillation and long-term use of artificial tears on TFT warrants further investigation. \copyright{} 2015 Wolters Kluwer Health, Inc. All rights reserved.},
  langid = {english},
  keywords = {Administration Topical,Adult,adult,Article,artificial tear,chemistry,comparative study,controlled study,disease duration,disease severity,double blind procedure,Double-Blind Method,drug combination,Drug Combinations,dry eye,Dry Eye Syndromes,Female,female,Fourier analysis,Fourier Analysis,human,Humans,hyaluronic acid,Hyaluronic Acid,intraocular pressure,lacrimal fluid,Lubricant Eye Drops,major clinical study,Male,male,metabolism,Middle Aged,middle aged,ocular surface disease,optical coherence tomography,outcome assessment,parallel design,patient satisfaction,priority journal,questionnaire,Questionnaires,randomized controlled trial,sodium chloride,tear film,tear film thickness,Tears,Tomography Optical Coherence,topical drug administration,trehalose,Trehalose,viscosupplement,Viscosupplements,visual acuity,visual system parameters},
  note = {Cited By :37

Export Date: 10 June 2020

CODEN: CORND

Correspondence Address: Garhofer, G.; Department of Clinical Pharmacology, Medical University Vienna, Waehringer Guertel 18-20, Austria}
}

