@article{sugitaMotionArtifactSpeckle2014,
  title = {Motion Artifact and Speckle Noise Reduction in Polarization Sensitive Optical Coherence Tomography by Retinal Tracking},
  author = {Sugita, Mitsuro and Zotter, Stefan and Pircher, Michael and Makihira, Tomoyuki and Saito, Kenichi and Tomatsu, Nobuhiro and Sato, Makoto and Roberts, Philipp and {Schmidt-Erfurth}, Ursula and Hitzenberger, Christoph K},
  year = 2014,
