}

@article{schlanitzIdentificationDrusenCharacteristics2015,
  title = {Identification of {{Drusen Characteristics}} in {{Age-Related Macular Degeneration}} by {{Polarization-Sensitive Optical Coherence Tomography}}},
  author = {Schlanitz, F G and Sacu, S and Baumann, B and Bolz, M and Platzer, M and Pircher, M and Hitzenberger, C K and {Schmidt-Erfurth}, U},
  year = 2015,
  journal = {American Journal of Ophthalmology},
  volume = {160},
  number = {2},
  pages = {335-344.e1},
  publisher = {Elsevier Inc.},
  address = {Department of Ophthalmology and Optometry, Medical University of Vienna, W\"ahringer G\"urtel 18-20, Vienna, 1090, Austria},
  issn = {00029394 (ISSN)},
  doi = {10.1016/j.ajo.2015.05.008},
  abstract = {Purpose To describe qualitative characteristics of drusen in eyes with nonadvanced age-related macular degeneration (AMD) using polarization-sensitive optical coherence tomography (OCT). Design Cross-sectional study. Methods Twenty-five eyes of 25 patients with early to intermediate (nonadvanced) AMD were imaged with polarization-sensitive OCT using macular volume scans. All individual drusen in each B-scan were manually delineated by experts certified by a reading center and graded for 6 different morphologic characteristics based on a defined classification scheme, including the presence of internal depolarizing structures and associated depolarizing foci. With the use of a custom-made software, the central B-scan of each individual druse was selected and used to analyze its location, diameter, and characteristics and assess the prevalence of the different features and relations between them. Results Using the macular volume scans, 6224 individual drusen could be identified, including their position within the retina, their characteristics, and their association with any pigmentary alterations. The most common drusen type was a convex-shaped druse with homogeneous medium internal reflectivity and no depolarizing contents (55.3\% of drusen). A total of 30.5\% of the drusen exhibited internal depolarizing material; 0.3\% presented overlying hyperreflective foci, and in 54.5\% the foci were also depolarizing. Significant correlations were found between the diameter of the drusen and their distribution throughout the retina, shape, homogeneity of internal reflectivity, presence of internal depolarizing characteristics, and presence of overlying foci (P {$<$}.001 each). Significant relations were found between reflectivity, homogeneity, and polarization-sensitive internal characteristics (P {$<$}.001). Conclusions Polarization-sensitive OCT reveals characteristic morphologic features of different druse types highlighting the pathophysiological spectrum of early to intermediate AMD. \copyright{} 2015 The Authors.},
  langid = {english},
  keywords = {adult,age related macular degeneration,Aged,aged,Aged 80 and over,Article,Austria,B scan,clinical article,clinical evaluation,clinical feature,clinical trial,complication,computer program,Cross-Sectional Studies,cross-sectional study,depolarization,disease classification,drusen,drusenoid pigment epithelial detachment,eye fundus,Female,female,Fluorescein Angiography,fluorescence angiography,Fundus Oculi,human,Humans,Macular Degeneration,macular degeneration,Male,male,Middle Aged,middle aged,observational study,optical coherence tomography,optical coherence tomography device,pathology,polarization,polarization sensitive optical coherence tomograph,prevalence,Prevalence,priority journal,procedures,qualitative analysis,Retina,retina,retina detachment,Retinal Drusen,Tomography Optical Coherence,very elderly},
  note = {Cited By :25

Export Date: 10 June 2020

CODEN: AJOPA

Correspondence Address: Schmidt-Erfurth, U.; Department of Ophthalmology and Optometry, Medical University of Vienna, W\"ahringer G\"urtel 18-20, Austria}
}

@article{schlanitzImpactDrusenDrusenoid2019,
  title = {Impact of Drusen and Drusenoid Retinal Pigment Epithelium Elevation Size and Structure on the Integrity of the Retinal Pigment Epithelium Layer},
  author = {Schlanitz, F and Baumann, B and Sacu, S and Baumann, L and Pircher, M and Hitzenberger, C K and {Schmidt-Erfurth}, U M},
  year = 2019,
  journal = {British Journal of Ophthalmology},
  volume = {103},
  number = {2},
  pages = {227--232},
  publisher = {BMJ Publishing Group},
  address = {Department of Ophthalmology and Optometry, Medical University of Vienna, W\"ahringer G\"urtel 18-20, Vienna, 1090, Austria},
  issn = {00071161 (ISSN)},
  doi = {10.1136/bjophthalmol-2017-311782},
  abstract = {Purpose To evaluate the impact of drusen size and structure on retinal pigment epithelium (RPE) and photoreceptor layers in eyes with early to intermediate age-related macular degeneration (AMD) using polarisation-sensitive optical coherence tomography (OCT). Design Retrospective investigation of an observational cross-sectional study. Participants Patients with early to intermediate AMD. Methods Twenty-five eyes of 25 patients with drusen were imaged with polarisation-sensitive OCT using macular volume scans. Each scan was manually graded for six distinct drusen characteristics and the integrity of both the overlying RPE and photoreceptor layer. The central scan of each single druse, as well as its diameter and location, were selected for statistical calculations. Results A total number of 5933 individual drusen including their adjacent RPE and photoreceptor layer were evaluated. 41.3\% of all drusen demonstrated an intact overlying RPE; in 28.1\% the RPE layer was irregular, but continuous. In 30.6\%, the RPE layer signal was discontinuous above the area of drusen. The level of RPE alteration was significantly related to shape (p{$<$}0.001), internal reflectivity (p{$<$}0.001) and homogeneity (p{$<$}0.001) of the drusen and their diameter, with a higher probability for larger drusen to have a discontinuous RPE (OR 3.2, p{$<$}0.001). The number of drusen showing overlying foci or an altered photoreceptor layer was too small to be conclusive, but showed a trend towards an altered RPE if present. Conclusions Polarisation-sensitive OCT reveals a correlation between specific drusen characteristics and the integrity of the overlying RPE layer. Drusen diameter and configuration were significantly associated with RPE loss. \copyright{} Author(s) (or their employer(s)) 2019. Re-use permitted under CC BY-NC. No commercial re-use. See rights and permissions. Published by BMJ.},
  langid = {english},
  keywords = {age related macular degeneration,Aged,aged,Aged 80 and over,Article,clinical article,correlational study,Cross-Sectional Studies,cross-sectional study,diagnostic imaging,disease association,drusen,Female,female,human,Humans,imaging,macula,Male,male,Middle Aged,middle aged,observational study,optical coherence tomography,pathology,photoreceptor,Photoreceptor Cells Vertebrate,priority journal,procedures,retina,retina detachment,Retinal Drusen,retinal pigment epithelium,Retinal Pigment Epithelium,Retrospective Studies,retrospective study,Tomography Optical Coherence,vertebrate photoreceptor cell,very elderly,Visual Acuity,visual acuity},
  note = {Cited By :4

