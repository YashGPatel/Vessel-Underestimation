}

@article{schmidlPharmacotherapyGlaucoma2015,
  title = {Pharmacotherapy of {{Glaucoma}}},
  author = {Schmidl, D and Schmetterer, L and Garh{\"o}fer, G and {Popa-Cherecheanu}, A},
  year = 2015,
