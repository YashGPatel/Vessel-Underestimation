@article{harperRetinalAnalysisMouse2020,
  title = {Retinal Analysis of a Mouse Model of {{Alzheimer}}'s Disease with Multicontrast Optical Coherence Tomography},
  author = {Harper, Danielle J. and Augustin, Marco and Lichtenegger, Antonia and Gesperger, Johanna and Himmel, Tanja and Muck, Martina and Merkle, Conrad W. and Eugui, Pablo and Kummer, Stefan and Woehrer, Adelheid and Gl{\"o}smann, Martin and Baumann, Bernhard},
  year = 2020,
  journal = {Neurophotonics},
  volume = {7},
  number = {1},
  eprint = {1909.08466},
  pages = {015006},
  publisher = {SPIE},
  address = {Medical University of Vienna, Center for Medical Physics and Biomedical Engineering, Vienna, Austria},
  issn = {2329-423X},
  doi = {10.1117/1.nph.7.1.015006},
  abstract = {Recent Alzheimer's disease (AD) patient studies have focused on retinal analysis, as the retina is the only part of the central nervous system which can be imaged non-invasively by optical methods. However as this is a relatively new approach, the occurrence and role of pathological features such as retinal layer thinning, extracellular amyloid beta (A\$\textbackslash beta\$) accumulation and vascular changes is still debated. Animal models of AD are therefore often used in attempts to understand the disease. In this work, both eyes of 24 APP/PS1 transgenic mice (age: 45-104 weeks) and 15 age-matched wildtype littermates were imaged by a custom-built multi-contrast optical coherence tomography (OCT) system. The system provided a combination of standard reflectivity data, polarization-sensitive data and OCT angiograms. This tri-fold contrast provided qualitative and quantitative information on retinal layer thickness and structure, presence of hyper-reflective foci, phase retardation abnormalities and retinal vasculature. While abnormal structural properties and phase retardation signals were observed in the retinas, the observations were very similar in transgenic and control mice. At the end of the experiment, retinas and brains were harvested from a subset of the mice (14 transgenic, 7 age-matched control) in order to compare the in vivo results to histological analysis, and to quantify the cortical A\$\textbackslash beta\$ plaque load.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {Age-matched controls,Alzheimer disease,Alzheimer's disease,amyloid beta,animal experiment,animal model,animal tissue,Article,brain,Bruch membrane,Central nervous systems,choroid,controlled study,external limiting membrane,female,Histological analysis,histology,image analysis,in vivo study,male,Mammals,mouse,Neurodegenerative diseases,nonhuman,Ophthalmology,optical coherence tomography,optical coherence tomography angiography,Optical tomography,Phase retardation,polarization,Polarization sensitive,Quantitative information,retina,retinal pigment epithelium,retinal thickness,Retinal vasculature,signal noise ratio,Tomography,transgenic mouse,vascularization,wild type mouse},
  note = {Export Date: 4 June 2020

Correspondence Address: Harper, D.J.; Medical University of Vienna, Center for Medical Physics and Biomedical EngineeringAustria; email: danielle.harper@meduniwien.ac.at}
}

@article{harperWhiteLightPolarization2018,
