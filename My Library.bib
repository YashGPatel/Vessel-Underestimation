@article{bataOpticNerveHead2019,
  title = {Optic Nerve Head Blood Flow Regulation during Changes in Arterial Blood Pressure in Patients with Primary Open-Angle Glaucoma},
  author = {Bata, A M and Fondi, K and Witkowska, K J and Werkmeister, R M and Hommer, A and Vass, C and Resch, H and Schmidl, D and {Popa-Cherecheanu}, A and Chua, J and Garh{\"o}fer, G and Schmetterer, L},
  year = 2019,
  journal = {Acta Ophthalmologica},
  volume = {97},
  number = {1},
  pages = {e36-e41},
  publisher = {Blackwell Publishing Ltd},
  address = {Department of Clinical Pharmacology, Medical University of Vienna, Vienna, Austria},
  issn = {1755375X (ISSN)},
  doi = {10.1111/aos.13850},
  abstract = {Purpose: Abnormal autoregulation of optic nerve head blood flow (ONHBF) has been postulated to play an important role in primary open-angle glaucoma (POAG). We used laser Doppler flowmetry (LDF) to estimate quantitatively the ONHBF and compared ONHBF autoregulation between glaucoma patients and healthy controls during isometric exercise. Methods: Forty patients with POAG and 40 healthy age- and sex-matched subjects underwent three periods of isometric exercise, each consisting of 2~min of handgripping. Optic nerve head blood flow (ONHBF) was measured continuously using LDF. Systemic blood pressure, intraocular pressure and ocular perfusion pressure were assessed in all participants. Results: Isometric exercise was associated with an increase in ocular perfusion pressure during all handgripping periods in both groups (p~{$<~$}0.001). However, there was no change in ONHBF in either group. Three of the glaucoma patients and two of the healthy subjects showed a consistent 10\% decrease in blood flow during isometric exercise, in spite of an increase in their blood pressure. This difference between groups was not significant (p~=~0.61). Four other glaucoma subjects showed a consistent increase in blood flow of more than 10\% during isometric exercise, whereas this was not seen in healthy subjects (p~=~0.035). Conclusion: This study suggests that abnormal ONHBF autoregulation is more often seen in patients with POAG than healthy control subjects. The relationship to the glaucoma disease process is currently unknown and requires further investigation. \copyright{} 2018 The Authors. Acta Ophthalmologica published by John Wiley \& Sons Ltd on behalf of Acta Ophthalmologica Scandinavica Foundation.},
  langid = {english},
  keywords = {adult,arterial pressure,Article,autoregulation,blood flow,Blood Flow Velocity,blood flow velocity,blood pressure,Blood Pressure,choroid,Choroid,clinical article,comparative study,controlled study,diastolic blood pressure,exercise,Exercise,Female,female,glaucoma,Glaucoma Open-Angle,hand grip,human,Humans,intraocular pressure,Intraocular Pressure,isometric exercise,laser doppler flowmetery,laser Doppler flowmetry,Laser-Doppler Flowmetry,Male,male,mean arterial pressure,Middle Aged,middle aged,oculoplethysmography,open angle glaucoma,optic disk,Optic Disk,optic nerve,optic nerve head autoregulation,optic nerve head blood flow,pathophysiology,physiology,priority journal,Regional Blood Flow,retinal nerve fiber layer thickness,systolic blood pressure,Tonometry Ocular,vascularization},
