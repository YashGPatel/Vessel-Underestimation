@article{moultEvaluatingAnestheticProtocols2017,
  title = {Evaluating Anesthetic Protocols for Functional Blood Flow Imaging in the Rat Eye},
  author = {Moult, E M and Choi, W and Boas, D A and Baumann, B and Clermont, A C and Feener, E P and Fujimoto, J G},
  year = 2017,
  journal = {Journal of Biomedical Optics},
  volume = {22},
  number = {1},
  publisher = {SPIE},
  address = {Massachusetts Institute of Technology, Research Laboratory of Electronics, Department of Electrical Engineering and Computer Science, 50 Vassar Street, Cambridge, 02139, United States},
  issn = {10833668 (ISSN)},
  doi = {10.1117/1.JBO.22.1.016005},
  abstract = {The purpose of this study is to evaluate the suitability of five different anesthetic protocols (isoflurane, isoflurane-xylazine, pentobarbital, ketamine-xylazine, and ketamine-xylazine-vecuronium) for functional blood flow imaging in the rat eye. Total retinal blood flow was measured at a series of time points using an ultrahigh-speed Doppler OCT system. Additionally, each anesthetic protocol was qualitatively evaluated according to the following criteria: (1) time-stability of blood flow, (2) overall rate of blood flow, (3) ocular immobilization, and (4) simplicity. We observed that different anesthetic protocols produced markedly different blood flows. Different anesthetic protocols also varied with respect to the four evaluated criteria. These findings suggest that the choice of anesthetic protocol should be carefully considered when designing and interpreting functional blood flow studies in the rat eye. \copyright{} 2017 The Author(s).},
  langid = {english},
  keywords = {Amines,Anesthesia,anesthesia,anesthetic agent,Anesthetics,animal,Animals,Blood,Blood flow,blood flow,Doppler OCT,drug effect,evaluation study,eye,Eye,Functional imaging,functional imaging,Hemodynamics,isoflurane,Isoflurane,ketamine,Ketamine,pentobarbital,Pentobarbital,procedures,rat,Rating,Rats,Regional Blood Flow,Retina,retina,small animal,Small Animal,Stability criteria,vascularization,vecuronium,Vecuronium Bromide,xylazine,Xylazine},
  note = {Cited By :6

Export Date: 10 June 2020

CODEN: JBOPF

Correspondence Address: Fujimoto, J.G.; Massachusetts Institute of Technology, Research Laboratory of Electronics, Department of Electrical Engineering and Computer Science, 50 Vassar Street, United States; email: jgfuji@mit.edu}
}

@article{mSignificanceBloodVessel2002,
  title = {Significance of Blood Vessel Leakiness in Cancer},
  author = {M, Donald M. and Baluk, Peter},
  year = 2002,
  journal = {Cancer Research},
  volume = {62},
  number = {18},
  pages = {5381--5385},
  issn = {00085472},
  doi = {10.1158/0008-5472.can-05-0002},
  abstract = {Despite major advances in the field of tumor angiogenesis, relatively little attention has been paid to the permeability of blood vessels in tumors. The leakiness of tumor vessels is well documented in experimental tumor models and in human cancer, but the mechanism is poorly understood, as are the implications to the rate of cancer growth, predisposition to metastasis, and delivery of macromolecular therapeutics to tumor cells. Sixteen experts in the fields of cancer biology and vascular biology gathered at the William Guy Forbeck "Focus on the Future" Conference to discuss this topic. The meeting was the first of its kind focused on the significance of blood vessel leakiness in tumors. The participants discussed the cellular basis of tumor vessel leakiness, endothelial barrier function of blood vessels, monitoring tumor vessel leakiness, mediators of endothelial leakiness, consequences of tumor vessel leakiness, genomic analysis of vascular targets, targeting drugs to tumor vessels, and therapeutic manipulation of tumor vessels. The group concluded that a more complete understanding of the basic biology of tumor vessels will be necessary to fully appreciate the consequences of vessel leakiness in cancer. New research tools such as intravital measurements of tumor blood flow and vessel leakiness, in vivo phage display, magnetic resonance imaging, and use of selective angiogenesis inhibitors will contribute to this understanding.},
  isbn = {0008-5472 (Print)},
  pmid = {12235011}
}

