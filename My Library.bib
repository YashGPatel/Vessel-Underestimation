@article{schmidlOcularPerfusionPressure2015,
  title = {{Ocular perfusion pressure and its relevance for glaucoma}},
  author = {Schmidl, D and Werkmeister, R and Garh{\"o}fer, G and Schmetterer, L},
  year = 2015,
  journal = {Klinische Monatsblatter fur Augenheilkunde},
