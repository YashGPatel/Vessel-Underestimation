}

@article{schmidlFactorsAssociatedChoroidal2016,
  title = {Factors Associated with Choroidal Blood Flow Regulation in Healthy Young Subjects},
  author = {Schmidl, D and Schmetterer, L and Witkowska, K J and Rauch, A and Werkmeister, R M and Garh{\"o}fer, G and {Popa-Cherecheanu}, A},
  year = 2016,
  journal = {Investigative Ophthalmology and Visual Science},
  volume = {57},
  number = {13},
  pages = {5705--5713},
  publisher = {{Association for Research in Vision and Ophthalmology Inc.}},
  address = {Department of Clinical Pharmacology, Medical University of Vienna, Vienna, Austria},
  issn = {01460404 (ISSN)},
  doi = {10.1167/iovs.16-20225},
  abstract = {PURPOSE. To analyze regulation of subfoveal choroidal blood flow (FLOW) during isometric exercise in healthy subjects in dependence of intraocular pressure (IOP), mean arterial pressure (MAP), ocular perfusion pressure (OPP), age, sex, fasting glucose, cholesterol, triglycerides, creatinine, and C-reactive protein levels and hematocrit. METHODS. We retrospectively analyzed results obtained in 261 healthy subjects who underwent a period of 6 minutes of isometric exercise during which FLOW was measured continuously and MAP was measured every minute. From these data, OPP and choroidal pressure/flow curves were calculated. Subjects were grouped into tertiles with regard to the dependent variables, and pressure/flow relationships were compared. RESULTS. Choroidal blood flow started to increase at OPP values of approximately 65\% dependent on the MAP/IOP tertile. A significant increase of FLOW from baseline was noted at 67.7 \textpm{} 2.1\% in the lowest MAP tertile, at 67.7 \textpm{} 2.0\% in the second MAP tertile, and at 61.8 \textpm{} 2.0\% in the highest MAP tertile (P {$\frac{1}{4}$} 0.01). At the three IOP levels, FLOW started to increase at an OPP increase of 69.8 \textpm{} 2.1\%, 70.1 \textpm{} 2.2\%, and 65.4 \textpm{} 1.9\% above baseline, respectively (P {$\frac{1}{4}$} 0.03). Choroidal pressure/flow curves were independent of the other variables. CONCLUSIONS. The present analysis indicates that FLOW regulation during isometric exercise is dependent on absolute MAP as well as IOP levels. This indicates that regulation depends on pressure levels at both the arterial and the venous side of the choroidal circulation and highlights the complexity of FLOW regulation during changes in OPP that cannot be simply characterized by classical autoregulation models. \copyright{} 2016, Association for Research in Vision and Ophthalmology Inc. All rights reserved.},
  langid = {english},
  keywords = {Adult,adult,age,Article,autoregulation,Autoregulation,blood flow,Blood pressure,C reactive protein,cholesterol,choroid,Choroid,choroidal blood flow,Choroidal blood flow,creatinine,exercise,Exercise,Female,female,glucose,Healthy Volunteers,hematocrit,homeostasis,Homeostasis,human,human experiment,Humans,intraocular pressure,Intraocular Pressure,isometric exercise,laser Doppler flowmetry,Laser-Doppler Flowmetry,Male,male,mean arterial pressure,normal human,ocular perfusion pressure,physiology,priority journal,pulse rate,Regional Blood Flow,Retrospective Studies,retrospective study,sex,triacylglycerol,vascularization,visual system parameters},
  note = {Cited By :7

