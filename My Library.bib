@article{euguiThreedimensionalVisualizationOpacifications2020,
  title = {Three-Dimensional Visualization of Opacifications in the Murine Crystalline Lens by in Vivo Optical Coherence Tomography},
  author = {Eugui, P and Harper, D J and Kummer, S and Lichtenegger, A and Gesperger, J and Himmel, T and Augustin, M and Merkle, C W and Gl{\"o}smann, M and Baumann, B},
