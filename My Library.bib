@article{eggerApplicationParallelizablePerfusion2017,
  title = {Application of a {{Parallelizable Perfusion Bioreactor}} for {{Physiologic 3D Cell Culture}}},
  author = {Egger, D and Spitz, S and Fischer, M and Handschuh, S and Gl{\"o}smann, M and Friemert, B and Egerbacher, M and Kasper, C},
  year = 2017,
  journal = {Cells Tissues Organs},
  volume = {203},
  number = {5},
  pages = {316--326},
  publisher = {S. Karger AG},
  address = {Department of Biotechnology, University of Natural Resources and Life Sciences, Muthgasse 18, Vienna, AT-1190, Austria},
  issn = {14226405 (ISSN)},
  doi = {10.1159/000457792},
  abstract = {It is crucial but challenging to keep physiologic conditions during the cultivation of 3D cell scaffold constructs for the optimization of 3D cell culture processes. Therefore, we demonstrate the benefits of a recently developed miniaturized perfusion bioreactor together with a specialized incubator system that allows for the cultivation of multiple samples while screening different conditions. Hence, a decellularized bone matrix was tested towards its suitability for 3D osteogenic differentiation under flow perfusion conditions. Subsequently, physiologic shear stress and hydrostatic pressure (HP) conditions were optimized for osteogenic differentiation of human mesenchymal stem cells (MSCs). X-ray computed microtomography and scanning electron microscopy (SEM) revealed a closed cell layer covering the entire matrix. Osteogenic differentiation assessed by alkaline phosphatase activity and SEM was found to be increased in all dynamic conditions. Furthermore, screening of different fluid shear stress (FSS) conditions revealed 1.5 mL/min (equivalent to {$\sim$}10 mPa shear stress) to be optimal. However, no distinct effect of HP compared to flow perfusion without HP on osteogenic differentiation was observed. Notably, throughout all experiments, cells cultivated under FSS or HP conditions displayed increased osteogenic differentiation, which underlines the importance of physiologic conditions. In conclusion, the bioreactor system was used for biomaterial testing and to develop and optimize a 3D cell culture process for the osteogenic differentiation of MSCs. Due to its versatility and higher throughput efficiency, we hypothesize that this bioreactor/incubator system will advance the development and optimization of a variety of 3D cell culture processes. \copyright{} 2017 S. Karger AG, Basel.},
  langid = {english},
  keywords = {3D cell culture,adult,alkaline phosphatase,Article,Biocompatible Materials,biomaterial,bioreactor,Bioreactors,bone development,bone matrix,case report,cell culture,cell culture technique,Cell Culture Techniques,cell differentiation,Cell Differentiation,cell viability,Cells Cultured,chemistry,controlled study,cultural anthropology,cytology,devices,Dynamic cultivation,enzyme activity,Equipment Design,equipment design,Female,female,Fluid shear stress,human,human cell,Humans,hydrostatic pressure,Hydrostatic pressure,Hydrostatic Pressure,mesenchymal stem cell,mesenchymal stroma cell,Mesenchymal Stromal Cells,Middle Aged,middle aged,miniaturized flow perfusion bioreactor,Osteogenesis,perfusion,Perfusion,Perfusion bioreactor system,porosity,Porosity,priority journal,scanning electron microscopy,shear stress,three dimensional cell culture,tissue engineering,Tissue Engineering,tissue scaffold,Tissue Scaffolds,x-ray computed tomography},
  note = {Cited By :13

Export Date: 10 June 2020

CODEN: CTORF}
}

@article{el-sadekThreedimensionalDynamicsOptical2021,
  title = {Three-Dimensional Dynamics Optical Coherence Tomography for Tumor Spheroid Evaluation},
  author = {{El-Sadek}, Ibrahim Abd and Miyazawa, Arata and Shen, Larina Tzu-Wei and Makita, Shuichi and Mukherjee, Pradipta and Lichtenegger, Antonia and Matsusaka, Satoshi and Yasuno, Yoshiaki},
  year = 2021,
  journal = {Biomedical Optics Express},
  volume = {12},
  number = {11},
  pages = {6844--6863},
  publisher = {Optica Publishing Group},
  doi = {10.1364/BOE.440444},
  abstract = {We present a completely label-free three-dimensional (3D) optical coherence tomography (OCT)-based tissue dynamics imaging method for visualization and quantification of the metabolic and necrotic activities of tumor spheroid. Our method is based on a custom 3D scanning protocol that is designed to capture volumetric tissue dynamics tomography images only in a few tens of seconds. The method was applied to the evaluation of a tumor spheroid. The time-course viability alteration and anti-cancer drug response of the spheroid were visualized qualitatively and analyzed quantitatively. The similarity between the OCT-based dynamics images and fluorescence microscope images was also demonstrated.},
  keywords = {Full field optical coherence tomography,Image processing,Imaging techniques,Polarimetric imaging,Three dimensional imaging,Tissue imaging}
}

