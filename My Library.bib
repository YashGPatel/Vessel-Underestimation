@article{schlanitzDrusenVolumeDevelopment2017,
  title = {Drusen Volume Development over Time and Its Relevance to the Course of Age-Related Macular Degeneration},
  author = {Schlanitz, F G and Baumann, B and Kundi, M and Sacu, S and Baratsits, M and Scheschy, U and Shahlaee, A and Mitterm{\"u}ller, T J and Montuoro, A and Roberts, P and Pircher, M and Hitzenberger, C K and {Schmidt-Erfurth}, U},
  year = 2017,
  journal = {British Journal of Ophthalmology},
  volume = {101},
  number = {2},
  pages = {198--203},
  publisher = {BMJ Publishing Group},
  address = {Department of Ophthalmology and Optometry, Medical University of Vienna, W\"ahringer G\"urtel 18-20, Vienna, 1090, Austria},
  issn = {00071161 (ISSN)},
  doi = {10.1136/bjophthalmol-2016-308422},
  abstract = {Aims To quantify the change in drusen volume over time and identify its prognostic value for individual risk assessment. Methods A prospective observational study over a minimum of 3 years and maximum of 5 years and follow-up examination every 3 months was conducted at the ophthalmology department of the Medical University of Vienna. 109 patients presenting early and intermediate age-related macular degeneration (AMD) were included, of which 30 patients concluded a regular follow-up for at least 3 years. 50 eyes of 30 patients were imaged every 3 months using spectral-domain and polarisation-sensitive optical coherence tomography (OCT). Drusen volume was measured using an automated algorithm. Data of a 6-month follow-up were segmented manually by expert graders. Results Gradings from 24 000 individual B-scans showed solid correlation between manual and automated segmentation with an initial mean drusen volume of 0.17 mm 3. The increase in drusen volume was shown to be comparable among all eyes, and a model for long-term drusen volume development could be fitted as a cubic polynomial function and an R 2 =0.955. Spontaneous drusen regression was observed in 22 of 50 eyes. In this group, four eyes developed choroidal neovascularisation and three geographic atrophy. Conclusions Drusen volume increase over time can be described by a cubic function. Spontaneous regression appears to precede conversion to advanced AMD. OCT might be a promising tool for predicting the individual risk of progression of AMD.},
  langid = {english},
  keywords = {adult,age related macular degeneration,Aged,aged,Aged 80 and over,algorithm,Algorithms,Article,Austria,automation,B scan,controlled study,Degeneration,diagnostic test accuracy study,disease course,Disease Progression,drusen,Female,female,Fluorescein Angiography,fluorescence angiography,follow up,geographic atrophy,Geographic Atrophy,human,Humans,Imaging,Macular Degeneration,macular degeneration,major clinical study,Male,male,Middle Aged,middle aged,observational study,ophthalmology,optical coherence tomography,optical coherence tomography device,pathology,polarisation sensitive optical coherence tomograph,predictive value,Predictive Value of Tests,procedures,prognosis,Prognosis,Prospective Studies,prospective study,reference value,remission,Retina,Retinal Drusen,risk assessment,spectral domain optical coherence tomography,subretinal neovascularization,Tomography Optical Coherence,university hospital,very elderly},
