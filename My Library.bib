  publisher = {Georg Thieme Verlag},
  address = {Universit\"atsklinik f\"ur Klinische Pharmakologie, Medizinische Universit\"at Wien, \"Osterreich, Austria},
  issn = {00232165 (ISSN)},
  doi = {10.1055/s-0034-1383398},
  abstract = {Ocular perfusion pressure is defined as the difference between arterial and venous pressure in ocular vessels. In practice, mean arterial pressure is used to substitute for arterial pressure in ocular vessels while intraocular pressure gives an estimate for ocular venous pressure. This results in a value that is easy to calculate and which is of importance since several studies have shown that it is correlated to the prevalence, incidence and progression of primary open angle glaucoma. Today, ocular perfusion pressure is used to estimate individual risks. Since no target value for ocular perfusion pressure can be defined, direct therapeutic intervention is difficult. Still, it has to be kept in mind that lowering intraocular pressure automatically leads to an increase in ocular perfusion pressure. The present article also points out problems and limitations in the concept of ocular perfusion pressure and suggests possible solutions for these problems in the future. \copyright{} Georg Thieme Verlag KG Stuttgart New York.},
  langid = {german},
  keywords = {animal,Animals,biological model,blood pressure,Blood Pressure,disease association,futurology,glaucoma,Glaucoma,human,Humans,intraocular hypertension,intraocular pressure,Intraocular Pressure,Models Cardiovascular,Ocular Hypertension,ocular perfusion pressure,pathophysiology,perfusion pressure,retina artery,retina vein,Retinal Artery,Retinal Vein,Review},
  note = {Cited By :7

