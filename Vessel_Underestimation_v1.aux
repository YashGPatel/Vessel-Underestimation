\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Linearity and accuracy of binarisation}{8}{subsection.3.3}\protected@file@percent }
\newlabel{subsec:linearity_accuracy_bw}{{3.3}{8}{Linearity and accuracy of binarisation}{subsection.3.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Binarisation-based (BW) vessel diameter versus ground truth for maximum intensity projection (MIP) at five threshold levels: (a) BW-1 (lowest) through (e) BW-5 (highest). Regression lines and statistics are shown for pre-contrast (blue), peak-contrast (green), and post-contrast (red) conditions. Both slope and $R^2$ decrease monotonically with increasing threshold stringency.}}{8}{figure.caption.5}\protected@file@percent }
\newlabel{fig:scatter_bw_mip}{{5}{8}{Binarisation-based (BW) vessel diameter versus ground truth for maximum intensity projection (MIP) at five threshold levels: (a) BW-1 (lowest) through (e) BW-5 (highest). Regression lines and statistics are shown for pre-contrast (blue), peak-contrast (green), and post-contrast (red) conditions. Both slope and $R^2$ decrease monotonically with increasing threshold stringency}{figure.caption.5}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Binarisation-based (BW) vessel diameter versus ground truth for mean intensity projection (MeIP) at five threshold levels: (a) BW-1 (lowest) through (e) BW-5 (highest). Regression lines and statistics are shown for pre-contrast (blue), peak-contrast (green), and post-contrast (red) conditions. MeIP yields higher slopes and more stable $R^2$ values compared with MIP (Fig.~\ref {fig:scatter_bw_mip}).}}{9}{figure.caption.6}\protected@file@percent }
\newlabel{fig:scatter_bw_meip}{{6}{9}{Binarisation-based (BW) vessel diameter versus ground truth for mean intensity projection (MeIP) at five threshold levels: (a) BW-1 (lowest) through (e) BW-5 (highest). Regression lines and statistics are shown for pre-contrast (blue), peak-contrast (green), and post-contrast (red) conditions. MeIP yields higher slopes and more stable $R^2$ values compared with MIP (Fig.~\ref {fig:scatter_bw_mip})}{figure.caption.6}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Repeatability and linearity summary}{10}{subsection.3.4}\protected@file@percent }
\newlabel{subsec:repeatability}{{3.4}{10}{Repeatability and linearity summary}{subsection.3.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Summary of repeatability and linearity across all diameter measurement methods. (a,b) Coefficient of variation (CoV) for MIP and MeIP, respectively. (c,d) Coefficient of determination ($R^2$) for MIP and MeIP, respectively. Bars are grouped by method (BW-1 through BW-5, G-$e^2$, GG-HM, GG-$e^2$) and colour-coded by contrast condition: pre-contrast (blue), peak-contrast (green), and post-contrast (red). Model-based methods consistently show lower CoV and higher $R^2$ than binarisation-based methods.}}{10}{figure.caption.7}\protected@file@percent }
\newlabel{fig:cov_r2}{{7}{10}{Summary of repeatability and linearity across all diameter measurement methods. (a,b) Coefficient of variation (CoV) for MIP and MeIP, respectively. (c,d) Coefficient of determination ($R^2$) for MIP and MeIP, respectively. Bars are grouped by method (BW-1 through BW-5, G-$e^2$, GG-HM, GG-$e^2$) and colour-coded by contrast condition: pre-contrast (blue), peak-contrast (green), and post-contrast (red). Model-based methods consistently show lower CoV and higher $R^2$ than binarisation-based methods}{figure.caption.7}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}Functional flicker stimulation}{11}{subsection.3.5}\protected@file@percent }
\newlabel{subsec:flicker}{{3.5}{11}{Functional flicker stimulation}{subsection.3.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Functional flicker stimulation results. (a--c) Time series of vessel diameter during baseline and post-stimulation periods for (a) Gaussian model, (b) generalised Gaussian model, and (c) binarised angiogram, across five vessels. Dashed lines indicate stimulation onset and offset. (d--f) Mean diameter per vessel before (dark bars) and after (light bars) stimulation for each method; veins are shown in blue/cyan and arteries in dark/light red. Significance levels: $^{**}p < 0.01$, $^{***}p < 0.001$. (g) Angiogram signal intensity time series and (h) mean intensity per vessel before and after stimulation. Model-based methods detect the expected vasodilation, whereas the binarised method paradoxically reports vasoconstriction.}}{11}{figure.caption.8}\protected@file@percent }
\newlabel{fig:flicker}{{8}{11}{Functional flicker stimulation results. (a--c) Time series of vessel diameter during baseline and post-stimulation periods for (a) Gaussian model, (b) generalised Gaussian model, and (c) binarised angiogram, across five vessels. Dashed lines indicate stimulation onset and offset. (d--f) Mean diameter per vessel before (dark bars) and after (light bars) stimulation for each method; veins are shown in blue/cyan and arteries in dark/light red. Significance levels: $^{**}p < 0.01$, $^{***}p < 0.001$. (g) Angiogram signal intensity time series and (h) mean intensity per vessel before and after stimulation. Model-based methods detect the expected vasodilation, whereas the binarised method paradoxically reports vasoconstriction}{figure.caption.8}{}}
\def\@LN@column{1}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Summary of flicker stimulation results. Top: percentage diameter change per vessel for each method together with corresponding $p$-values. Bottom: Pearson correlation ($\rho $) between measured diameter and angiogram signal intensity for each method and vessel. Overall correlations: Gaussian $= -0.101$, GG $= -0.098$, BW $= 0.523$.}}{12}{table.caption.9}\protected@file@percent }
\newlabel{fig:table}{{1}{12}{Summary of flicker stimulation results. Top: percentage diameter change per vessel for each method together with corresponding $p$-values. Bottom: Pearson correlation ($\rho $) between measured diameter and angiogram signal intensity for each method and vessel. Overall correlations: Gaussian $= -0.101$, GG $= -0.098$, BW $= 0.523$}{table.caption.9}{}}
