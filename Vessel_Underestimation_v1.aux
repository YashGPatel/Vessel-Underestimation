\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Modelled vessel diameter versus contrast-enhanced ground truth diameter for model-based methods. Top row: maximum intensity projection (MIP); bottom row: mean intensity projection (MeIP). Columns correspond to (a,b) Gaussian $1/e^2$ width, (c,d) GG FWHM, and (e,f) GG $1/e^2$ width. Regression lines and statistics are shown for pre-contrast (blue), peak-contrast (green), and post-contrast (red) conditions. The black line indicates the identity line ($m = 1$).}}{7}{figure.caption.4}\protected@file@percent }
\newlabel{fig:scatter_model}{{4}{7}{Modelled vessel diameter versus contrast-enhanced ground truth diameter for model-based methods. Top row: maximum intensity projection (MIP); bottom row: mean intensity projection (MeIP). Columns correspond to (a,b) Gaussian $1/e^2$ width, (c,d) GG FWHM, and (e,f) GG $1/e^2$ width. Regression lines and statistics are shown for pre-contrast (blue), peak-contrast (green), and post-contrast (red) conditions. The black line indicates the identity line ($m = 1$)}{figure.caption.4}{}}
